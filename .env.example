# Required
NANIT_EMAIL=you@example.com
NANIT_PASSWORD=your-nanit-password
NANIT_RTMP_ADDR=auto                  # LAN IP reachable by the camera (auto-detected on install)

# Optional
# NANIT_HTTP_PORT=8080
# NANIT_SENSOR_POLL_SEC=30
# NANIT_MQTT_BROKER_URL=tcp://192.168.1.50:1883
# NANIT_MQTT_USERNAME=
# NANIT_MQTT_PASSWORD=
# NANIT_MQTT_PREFIX=nanit
# NANIT_DASHBOARD_PASSWORD=
# NANIT_RTMP_TOKEN=                    # override auto-generated token (min 8 chars)
